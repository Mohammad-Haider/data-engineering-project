# Copy this file to ".env" in the same folder and fill in values.
# The real ".env" file is gitignored — never commit secrets.

# --- Kaggle (for scripts/download_kaggle_datasets.py and bootstrap_kaggle_to_database.py)
# Get username + key from: https://www.kaggle.com/settings -> API -> Create New Token
# (You can use the downloaded kaggle.json in ~/.kaggle/ instead of these two lines.)
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- MySQL (optional; defaults match docker-compose in main_pipeline.py)
# DATABASE_URL=mysql+pymysql://appuser:apppassword@localhost:3307/job_market_db

# --- Job APIs (optional; only if you run the full Prefect pipeline with live APIs)
# JSEARCH_API_KEY=
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=gb

# --- Data cleaning (data_transformation/cleaners.py)
# PIPELINE_FALLBACK_COMPANY=Employer not listed
# PIPELINE_NULL_LOCATION_DEFAULT=Unknown
# IMPUTE_SALARY_WITH_BATCH_MEDIAN=1
# IMPUTE_SALARY_MIN_KNOWN_ROWS=15
